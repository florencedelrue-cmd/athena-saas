# ============================================================
# ATHENA TOCI 2.0 — Environment Variables
# ============================================================
# Lokaal:  kopieer naar .env.local
# Vercel:  Project → Settings → Environment Variables
#           (Production + Preview + Development voor Supabase keys)
# ============================================================

# ── SUPABASE (verplicht) ─────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Alleen server-side (signup). NOOIT in client code!
# Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── APP URL (verplicht op Vercel Production) ───────────────
# Lokaal:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Vercel Production (pas aan na eerste deploy):
# NEXT_PUBLIC_APP_URL=https://jouw-project.vercel.app

# ── STRIPE (optioneel — billing prep) ───────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── DEMO ACCOUNTS (na npm run seed-demo) ─────────────────────
# CLW:   els.vermeulen@athena-clw.be   / AthenaDemo2026!
# Heule: marie.claes@athena-heule.be  / AthenaDemo2026!
#
# Seed commando:
# SUPABASE_URL=... SUPABASE_SERVICE_ROLE_KEY=... npm run seed-demo
# 1. Run supabase/COMPLETE_SETUP.sql in Supabase SQL Editor
# 2. Zet bovenstaande vars in Vercel (alle Production scopes)
# 3. git push → Vercel deployt automatisch
# 4. Registreer account op /signup → demo-data wordt aangemaakt
# 5. Controleer env: node scripts/check-env.mjs
# ============================================================
